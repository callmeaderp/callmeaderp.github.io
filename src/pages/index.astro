---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Joshua Beldue — Resume">

  <!-- ═══ Sticky Nav ═══ -->
  <nav class="no-print fixed top-0 inset-x-0 z-50 bg-surface/80 backdrop-blur-lg border-b border-border">
    <div class="max-w-5xl mx-auto px-6 flex items-center justify-between h-14">
      <span class="font-bold text-sm tracking-wide text-text shrink-0">JB</span>

      <!-- Desktop links -->
      <div class="hidden sm:flex gap-6 text-sm font-medium">
        <a href="#about"      class="text-text-muted border-b-2 border-transparent hover:text-accent transition-colors py-1">About</a>
        <a href="#experience" class="text-text-muted border-b-2 border-transparent hover:text-accent transition-colors py-1">Experience</a>
        <a href="#skills"     class="text-text-muted border-b-2 border-transparent hover:text-accent transition-colors py-1">Skills</a>
        <a href="#education"  class="text-text-muted border-b-2 border-transparent hover:text-accent transition-colors py-1">Education</a>
        <a href="#portfolio"  class="text-text-muted border-b-2 border-transparent hover:text-accent transition-colors py-1">Portfolio</a>
      </div>

      <!-- Mobile hamburger button -->
      <button id="menu-toggle" class="sm:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5 group" aria-label="Toggle menu">
        <span class="block w-5 h-0.5 bg-text-muted group-hover:bg-accent transition-all origin-center" id="bar-1"></span>
        <span class="block w-5 h-0.5 bg-text-muted group-hover:bg-accent transition-all" id="bar-2"></span>
        <span class="block w-5 h-0.5 bg-text-muted group-hover:bg-accent transition-all origin-center" id="bar-3"></span>
      </button>
    </div>

    <!-- Mobile dropdown -->
    <div id="mobile-menu" class="sm:hidden hidden border-t border-border bg-surface/95 backdrop-blur-lg">
      <div class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-3">
        <a href="#about"      class="mobile-nav-link text-text-muted hover:text-accent transition-colors text-sm font-medium py-2 border-b border-border/50">About</a>
        <a href="#experience" class="mobile-nav-link text-text-muted hover:text-accent transition-colors text-sm font-medium py-2 border-b border-border/50">Experience</a>
        <a href="#skills"     class="mobile-nav-link text-text-muted hover:text-accent transition-colors text-sm font-medium py-2 border-b border-border/50">Skills</a>
        <a href="#education"  class="mobile-nav-link text-text-muted hover:text-accent transition-colors text-sm font-medium py-2 border-b border-border/50">Education</a>
        <a href="#portfolio"  class="mobile-nav-link text-text-muted hover:text-accent transition-colors text-sm font-medium py-2">Portfolio</a>
      </div>
    </div>
  </nav>

  <script>
    const toggle = document.getElementById('menu-toggle')!;
    const menu = document.getElementById('mobile-menu')!;
    const bar1 = document.getElementById('bar-1')!;
    const bar2 = document.getElementById('bar-2')!;
    const bar3 = document.getElementById('bar-3')!;

    toggle.addEventListener('click', () => {
      const open = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', open);
      // Animate bars into X / back to hamburger
      bar1.style.transform = open ? '' : 'translateY(4px) rotate(45deg)';
      bar2.style.opacity   = open ? '1' : '0';
      bar3.style.transform = open ? '' : 'translateY(-4px) rotate(-45deg)';
    });

    // Close menu on link click
    document.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        bar1.style.transform = '';
        bar2.style.opacity = '1';
        bar3.style.transform = '';
      });
    });
  </script>

  <!-- ═══ Hero ═══ -->
  <section id="about" class="relative pt-32 pb-20 px-6 overflow-hidden">
    <!-- Background gradient orbs -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-accent/5 rounded-full blur-3xl -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent/3 rounded-full blur-3xl translate-y-1/2 pointer-events-none"></div>

    <div class="max-w-5xl mx-auto relative">
      <!-- Status badge -->
      <div class="animate-on-scroll mb-6">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-green/30 bg-green-glow text-green text-xs font-medium">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green"></span>
          </span>
          Available for opportunities
        </span>
      </div>

      <h1 class="animate-on-scroll text-5xl sm:text-6xl font-extrabold tracking-tight leading-tight mb-4">
        Joshua <span class="text-accent">Beldue</span>
      </h1>
      <p class="animate-on-scroll text-xl sm:text-2xl text-text-muted font-light mb-8 max-w-2xl">
        Web Developer & Digital Marketing Specialist
      </p>

      <!-- Summary card -->
      <div class="animate-on-scroll scale max-w-3xl bg-card border border-border rounded-xl p-6 relative" style="animation-delay: 200ms;">
        <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-accent to-accent/20 rounded-l-xl"></div>
        <p class="text-text-muted leading-relaxed pl-4">
          Web developer and digital marketing specialist with a background in applied computing.
          Currently the in-house IT and marketing lead for a 26-year-old landscaping company, where I
          built their production website from scratch, migrated their entire digital infrastructure,
          eliminated over <span class="text-text font-semibold">$13,000/year</span> in wasteful vendor spend,
          and set up conversion-tracked advertising across Google and Meta. Full-stack capabilities:
          website development, DNS and email infrastructure, ad platform management, analytics, SEO,
          security hardening, and print marketing design.
        </p>
      </div>

      <!-- Contact row -->
      <div class="animate-on-scroll flex flex-wrap gap-4 mt-8 text-sm" style="animation-delay: 300ms;">
        <a href="mailto:joshuabeldue@gmail.com"
           class="group flex items-center gap-2 px-4 py-2 rounded-lg bg-card border border-border hover:border-accent transition-colors">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="text-text-muted group-hover:text-text transition-colors">joshuabeldue@gmail.com</span>
        </a>
        <a href="tel:+15857362121"
           class="group flex items-center gap-2 px-4 py-2 rounded-lg bg-card border border-border hover:border-accent transition-colors">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="text-text-muted group-hover:text-text transition-colors">(585) 736-2121</span>
        </a>
        <a href="https://github.com/callmeaderp" target="_blank" rel="noopener"
           class="group flex items-center gap-2 px-4 py-2 rounded-lg bg-card border border-border hover:border-accent transition-colors">
          <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          <span class="text-text-muted group-hover:text-text transition-colors">github.com/callmeaderp</span>
        </a>
        <span class="flex items-center gap-2 px-4 py-2 rounded-lg bg-card border border-border">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="text-text-muted">Scottsville, NY</span>
        </span>
      </div>
    </div>
  </section>

  <!-- ═══ Impact Stats ═══ -->
  <section class="py-12 px-6 border-y border-border bg-card-alt">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="animate-on-scroll text-center" style="animation-delay: 0ms;">
        <div class="text-3xl font-bold text-accent" data-counter="13000" data-prefix="$" data-suffix="+">$0</div>
        <div class="text-xs text-text-muted mt-1 uppercase tracking-wider">Annual Waste Eliminated</div>
      </div>
      <div class="animate-on-scroll text-center" style="animation-delay: 100ms;">
        <div class="text-3xl font-bold text-accent" data-counter="19">0</div>
        <div class="text-xs text-text-muted mt-1 uppercase tracking-wider">Page Production Website</div>
      </div>
      <div class="animate-on-scroll text-center" style="animation-delay: 200ms;">
        <div class="text-3xl font-bold text-accent" data-counter="100" data-suffix="/100">0</div>
        <div class="text-xs text-text-muted mt-1 uppercase tracking-wider">Lighthouse Score (all 4)</div>
      </div>
      <div class="animate-on-scroll text-center" style="animation-delay: 300ms;">
        <div class="text-3xl font-bold text-accent" data-counter="306">0</div>
        <div class="text-xs text-text-muted mt-1 uppercase tracking-wider">USPS Routes Scored</div>
      </div>
    </div>
  </section>

  <!-- ═══ Experience ═══ -->
  <section id="experience" class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="animate-on-scroll text-3xl font-bold mb-12 flex items-center gap-3">
        <span class="text-accent font-mono text-lg">01.</span>
        Professional Experience
      </h2>

      <!-- Timeline -->
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-[19px] top-2 bottom-2 w-px bg-border hidden md:block"></div>

        <!-- Job 1: Westside -->
        <div class="animate-on-scroll slide-left mb-12 md:pl-14 relative">
          <!-- Timeline dot -->
          <div class="hidden md:flex absolute left-0 top-1 w-10 h-10 items-center justify-center">
            <div class="w-3 h-3 rounded-full bg-accent ring-4 ring-accent-glow"></div>
          </div>

          <div class="bg-card border border-border rounded-xl overflow-hidden hover:border-accent/40 transition-colors group">
            <!-- Header -->
            <div class="p-6 pb-4 border-b border-border bg-gradient-to-r from-card to-card-alt">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                <div>
                  <h3 class="text-xl font-bold group-hover:text-accent transition-colors">Westside Professional Landscape</h3>
                  <p class="text-accent font-medium text-sm mt-1">IT & Digital Marketing Lead</p>
                </div>
                <span class="text-xs font-mono text-text-muted bg-surface px-3 py-1 rounded-full whitespace-nowrap self-start">
                  Nov 2025 &mdash; Present
                </span>
              </div>
              <p class="text-text-muted text-sm leading-relaxed mt-3 italic">
                Hired as a licensed pesticide technician; took over all digital operations after identifying that two vendors were underperforming. Now sole person responsible for web, email, advertising, analytics, and marketing collateral.
              </p>
            </div>

            <!-- Accomplishments -->
            <div class="p-6 stagger-children">
              <div class="flex gap-3 py-3 border-b border-border/50">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Built a 19-page production website</strong> <span class="text-text-muted">(Astro, Tailwind CSS, TypeScript) deployed on Cloudflare Pages &mdash; Lighthouse scores of 100 across Performance, Accessibility, Best Practices, and SEO on launch</span></p>
              </div>
              <div class="flex gap-3 py-3 border-b border-border/50">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Migrated DNS to Cloudflare</strong> <span class="text-text-muted">and email to Microsoft 365 Exchange Online (12 users), replacing a legacy hosting stack and saving ~$710/year on email alone</span></p>
              </div>
              <div class="flex gap-3 py-3 border-b border-border/50">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Eliminated $12,830/year in vendor spend</strong> <span class="text-text-muted">after auditing services and documenting zero measurable value &mdash; dormant Google Ads, unverified Business Profile, no conversion tracking. Purged unauthorized vendor access from all ad platforms</span></p>
              </div>
              <div class="flex gap-3 py-3 border-b border-border/50">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Set up full analytics and ad tracking:</strong> <span class="text-text-muted">GA4, Google Ads conversion tags (form submissions + phone call clicks), Meta Pixel, and internal traffic filtering via Cloudflare transform rules</span></p>
              </div>
              <div class="flex gap-3 py-3 border-b border-border/50">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Built the contact form backend</strong> <span class="text-text-muted">using Cloudflare Pages Functions, Microsoft Graph API, Azure AD, and Cloudflare Turnstile CAPTCHA</span></p>
              </div>
              <div class="flex gap-3 py-3 border-b border-border/50">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Designed all spring marketing collateral:</strong> <span class="text-text-muted">EDDM postcards, door hangers, and 20+ flyer concepts iterated through review with the owner</span></p>
              </div>
              <div class="flex gap-3 py-3 border-b border-border/50">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Built an EDDM route targeting model</strong> <span class="text-text-muted">&mdash; geocoded existing clients, scored 306 USPS carrier routes with a 12-factor model, and produced a route report used by the print vendor</span></p>
              </div>
              <div class="flex gap-3 py-3">
                <span class="text-accent mt-0.5 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                </span>
                <p class="text-sm leading-relaxed"><strong class="text-text">Produced professional documents</strong> <span class="text-text-muted">for committee meetings: marketing overviews, competitive analyses, vendor cost breakdowns, SEO audits, and ad platform audit reports</span></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Job 2: RIT -->
        <div class="animate-on-scroll slide-left mb-4 md:pl-14 relative">
          <div class="hidden md:flex absolute left-0 top-1 w-10 h-10 items-center justify-center">
            <div class="w-3 h-3 rounded-full bg-border ring-4 ring-surface"></div>
          </div>

          <div class="bg-card border border-border rounded-xl overflow-hidden hover:border-accent/40 transition-colors group">
            <div class="p-6">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <div>
                  <h3 class="text-lg font-bold group-hover:text-accent transition-colors">Rochester Institute of Technology</h3>
                  <p class="text-accent font-medium text-sm mt-1">Research Technician &mdash; Materials Science Lab</p>
                </div>
                <span class="text-xs font-mono text-text-muted bg-surface px-3 py-1 rounded-full whitespace-nowrap self-start">
                  Jun 2024 &mdash; Aug 2025
                </span>
              </div>
              <ul class="space-y-2 mt-4">
                <li class="flex gap-3 text-sm text-text-muted leading-relaxed">
                  <span class="text-accent mt-0.5 shrink-0">&bull;</span>
                  Operated and troubleshot analytical lab equipment; developed SOPs and technical documentation
                </li>
                <li class="flex gap-3 text-sm text-text-muted leading-relaxed">
                  <span class="text-accent mt-0.5 shrink-0">&bull;</span>
                  Managed data systems, trained team members on equipment, and coordinated with external partners
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Skills ═══ -->
  <section id="skills" class="py-20 px-6 bg-card-alt border-y border-border">
    <div class="max-w-5xl mx-auto">
      <h2 class="animate-on-scroll text-3xl font-bold mb-12 flex items-center gap-3">
        <span class="text-accent font-mono text-lg">02.</span>
        Technical Skills
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Web Dev -->
        <div class="animate-on-scroll scale bg-card border border-border rounded-xl p-6 hover:border-accent/40 transition-all hover:shadow-lg hover:shadow-accent-glow/5 group" style="animation-delay: 0ms;">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <h3 class="font-bold text-lg">Web Development</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {['HTML/CSS/JS', 'TypeScript', 'Astro', 'Tailwind CSS', 'Responsive Design', 'Cloudflare Pages', 'Workers', 'REST APIs', 'Git'].map((skill) => (
              <span class="px-3 py-1 rounded-md bg-surface text-text-muted text-xs font-medium border border-border hover:border-accent hover:text-accent transition-colors cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Digital Marketing -->
        <div class="animate-on-scroll scale bg-card border border-border rounded-xl p-6 hover:border-accent/40 transition-all hover:shadow-lg hover:shadow-accent-glow/5 group" style="animation-delay: 100ms;">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
            </div>
            <h3 class="font-bold text-lg">Digital Marketing & SEO</h3>
          </div>
          <div class="flex flex-wrap gap-2">
